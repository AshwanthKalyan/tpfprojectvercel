{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build:client",
  "outputDirectory": "dist/public",
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/projects/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/users/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/sign-in/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/sign-up/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/:path((?!api/)(?!.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
